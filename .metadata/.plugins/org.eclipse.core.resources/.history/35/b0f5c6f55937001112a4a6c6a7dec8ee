package com.example.demo.controller;

import static org.mockito.Mockito.when;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*;

import com.example.demo.entity.Room;
import com.example.demo.service.RoomService;
import com.fasterxml.jackson.databind.ObjectMapper;

import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.test.web.servlet.MockMvc;

import java.util.List;

import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

@WebMvcTest(RoomController.class)
class RoomControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockBean
    private RoomService service;

    ObjectMapper mapper = new ObjectMapper();

    @Test
    void testAddRoom() throws Exception {

        Room r = new Room("AC", 2000, true);

        when(service.addRoom(any())).thenReturn(r);

        mockMvc.perform(post("/rooms")
                .contentType("application/json")
                .content(mapper.writeValueAsString(r)))
                .andExpect(status().isOk());
    }

    @Test
    void testValidationFail() throws Exception {

        Room r = new Room("", -1, true);

        mockMvc.perform(post("/rooms")
                .contentType("application/json")
                .content(mapper.writeValueAsString(r)))
                .andExpect(status().isBadRequest());
    }

    @Test
    void testGetRooms() throws Exception {
        when(service.getAllRooms()).thenReturn(List.of(new Room("AC", 2000, true)));

        mockMvc.perform(get("/rooms"))
                .andExpect(status().isOk());
    }

    @Test
    void testGetRoomById() throws Exception {
        when(service.getRoomById(1)).thenReturn(new Room("AC", 2000, true));

        mockMvc.perform(get("/rooms/1"))
                .andExpect(status().isOk());
    }

    @Test
    void testGetAvailableRooms() throws Exception {
        when(service.getAvailableRooms()).thenReturn(List.of(new Room("AC", 2000, true)));

        mockMvc.perform(get("/rooms/available"))
                .andExpect(status().isOk());
    }

    @Test
    void testSearchRooms() throws Exception {
        when(service.getAvailableRooms()).thenReturn(List.of(new Room("AC", 2000, true)));

        mockMvc.perform(get("/rooms/search"))
                .andExpect(status().isOk());
    }

    @Test
    void testUpdateRoom() throws Exception {

        Room r = new Room("DELUXE", 3000, false);

        when(service.updateRoom(anyInt(), any())).thenReturn(r);

        mockMvc.perform(put("/rooms/1")
                .contentType("application/json")
                .content(mapper.writeValueAsString(r)))
                .andExpect(status().isOk());
    }

    @Test
    void testDeleteRoom() throws Exception {

        mockMvc.perform(delete("/rooms/1"))
                .andExpect(status().isOk())
                .andExpect(content().string("Room deleted successfully"));
    }
}