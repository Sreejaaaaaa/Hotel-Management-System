package com.example.demo.controller;

import static org.mockito.Mockito.when;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*;

import com.example.demo.entity.Payment;
import com.example.demo.repository.PaymentRepository;
import com.fasterxml.jackson.databind.ObjectMapper;

import org.junit.jupiter.api.Test;
import org.mockito.Mockito;

import java.util.Arrays;
import java.util.List;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
import org.springframework.boot.test.mock.mockito.MockBean;
import org.springframework.http.MediaType;
import org.springframework.test.web.servlet.MockMvc;

import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

@WebMvcTest(PaymentController.class)
class PaymentControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockBean
    private PaymentRepository repo;

    private ObjectMapper mapper = new ObjectMapper();

    @Test
    void testMakePayment() throws Exception {

        Payment p = new Payment(1, 1000, "SUCCESS");

        when(repo.save(Mockito.any())).thenReturn(p);

        mockMvc.perform(post("/payments")
                .contentType(MediaType.APPLICATION_JSON)
                .content(mapper.writeValueAsString(p)))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.status").value("SUCCESS"));
    }

    @Test
    void testMakePaymentValidationFail() throws Exception {

        Payment p = new Payment();   // ✅ use default constructor
        p.setBookingId(null);        // ✅ now allowed (Integer)
        p.setAmount(-10);
        p.setStatus("");

        mockMvc.perform(post("/payments")
                .contentType(MediaType.APPLICATION_JSON)
                .content(mapper.writeValueAsString(p)))
                .andExpect(status().isBadRequest());
    }

    @Test
    void testGetAllPayments() throws Exception {

        Payment p = new Payment(1, 1000, "SUCCESS");

        when(repo.findAll()).thenReturn(Arrays.asList(p));

        mockMvc.perform(get("/payments"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$[0].bookingId").value(1));
    }

    @Test
    void testGetPaymentsByBooking() throws Exception {

        Payment p1 = new Payment(1, 1000, "SUCCESS");
        Payment p2 = new Payment(2, 2000, "SUCCESS");

        when(repo.findAll()).thenReturn(Arrays.asList(p1, p2));

        mockMvc.perform(get("/payments/booking/1"))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$[0].bookingId").value(1));
    }

    @Test
    void testGetPaymentsByBookingEmpty() throws Exception {

        Payment p = new Payment(2, 2000, "SUCCESS");

        when(repo.findAll()).thenReturn(List.of(p));

        mockMvc.perform(get("/payments/booking/1"))
                .andExpect(status().isOk())
                .andExpect(content().json("[]"));
    }
}