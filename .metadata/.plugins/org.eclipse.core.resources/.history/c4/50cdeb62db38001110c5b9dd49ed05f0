package com.example.billing.service;

import com.example.billing.entity.Bill;
import com.example.billing.repository.BillRepository;

import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.BeforeEach;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;

import java.util.List;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

class BillingServiceTest {

    @Mock
    private BillRepository repo;

    @InjectMocks
    private BillingService service;

    @BeforeEach
    void setup() {
        MockitoAnnotations.openMocks(this);
    }

    @Test
    void testGenerateBill() {

        Bill bill = new Bill();
        bill.setAmount(100);
        bill.setTax(10);

        when(repo.save(any(Bill.class))).thenAnswer(i -> i.getArgument(0));

        Bill result = service.generateBill(bill);

        assertEquals(110, result.getTotal());
        verify(repo, times(1)).save(bill);
    }

    @Test
    void testGetAllBills() {

        when(repo.findAll()).thenReturn(List.of(new Bill(), new Bill()));

        List<Bill> result = service.getAllBills();

        assertEquals(2, result.size());
        verify(repo, times(1)).findAll();
    }
}